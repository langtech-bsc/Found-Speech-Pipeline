Bootstrap: docker
From: pytorch/pytorch:2.5.1-cuda12.4-cudnn9-runtime

%labels
    Author Codex
    Description GPU-only Apptainer image for Galician HF ASR enrichment

%environment
    export PYTHONUNBUFFERED=1
    export PIP_NO_CACHE_DIR=1
    export HF_HUB_DISABLE_TELEMETRY=1
    export TRANSFORMERS_OFFLINE=1
    export HF_HUB_OFFLINE=1
    export PATH=/opt/fsp-gl-enrichment/.venv/bin:$PATH

%files
    environments/gl-enrichment/pyproject.toml /opt/fsp-gl-enrichment/pyproject.toml
    environments/gl-enrichment/uv.lock /opt/fsp-gl-enrichment/uv.lock

%post
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends ffmpeg libsndfile1 git
    rm -rf /var/lib/apt/lists/*

    python -m pip install --no-cache-dir uv==0.11.15
    cd /opt/fsp-gl-enrichment
    UV_PYTHON_DOWNLOADS=never uv sync --locked --no-dev --no-install-project

%runscript
    exec python "$@"
